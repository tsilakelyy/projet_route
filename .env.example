# Configuration PostgreSQL
# Ports hote personnalisables (pour eviter les conflits sur un autre PC)
POSTGRES_HOST_PORT=5433
BACKEND_HOST_PORT=8082
CARTE_HOST_PORT=3000
WEB_HOST_PORT=5173
MOBILE_HOST_PORT=8100
FRONTEND_REACT_HOST_PORT=3001

# Configuration Backend Spring
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/projet_route
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://192.168.*:*,http://10.*:*,capacitor://localhost,ionic://localhost

# Optionnel: chemin du service account Firebase dans le conteneur backend
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_DIR=./fournisseurIdentite/src/main/resources/firebase

# Optionnel: cle Web API Firebase (fallback REST pour sync comptes mobile)
# FIREBASE_WEB_API_KEY=AIzaSyCWvgIshY4Abcr6BdlK_7YifhMi0amz9QA

# Optionnel: manager bootstrap (cree automatiquement au demarrage backend)

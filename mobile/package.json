{
  "name": "mobile",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node ./scripts/ensure-deps.mjs",
    "build": "node --max-old-space-size=2048 ./node_modules/vue-tsc/bin/vue-tsc.js && node --max-old-space-size=2048 ./node_modules/vite/bin/vite.js build",
    "build:ci": "node --max-old-space-size=2048 ./node_modules/vue-tsc/bin/vue-tsc.js && node --max-old-space-size=2048 ./node_modules/vite/bin/vite.js build",
    "build:docker": "node --max-old-space-size=1536 ./node_modules/vite/bin/vite.js build",
    "cap:add:ios": "npx cap add ios",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest run",
    "lint": "eslint .",
    "apk:build:debug": "node ./scripts/build-apk.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "8.0.0",
    "@capacitor/camera": "8.0.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "8.0.0",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/http": "^0.0.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/local-notifications": "8.0.0",
    "@capacitor/push-notifications": "8.0.0",
    "@capacitor/status-bar": "8.0.0",
    "@ionic/vue": "^8.0.0",
    "@ionic/vue-router": "^8.0.0",
    "axios": "^1.13.2",
    "firebase": "^12.9.0",
    "ionicons": "^7.0.0",
    "leaflet": "^1.9.4",
    "leaflet.vectorgrid": "^1.3.0",
    "pbf": "^4.0.1",
    "vue": "^3.3.0",
    "vue-leaflet": "^0.1.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.5.0",
    "eslint": "^8.35.0",
    "eslint-plugin-vue": "^9.9.0",
    "jsdom": "^22.1.0",
    "patch-package": "^8.0.1",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "vite": "5.4.21",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.1.10"
  },
  "description": "An Ionic project"
}
